# KÜYEN - Environment Configuration Template
# Copy this file to .env.local and configure your actual values

# Application General
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=KÜYEN

# JWT Session Authentication
JWT_SECRET=kuyen_admin_default_secret_key_change_me

# Turso Database (LibSQL)
TURSO_CONNECTION_URL=your-turso-db-url-here
TURSO_AUTH_TOKEN=your-turso-auth-token-here

# Cloudinary Integration (Image Upload)
CLOUDINARY_CLOUD_NAME=x9zkuwyc
CLOUDINARY_API_KEY=your-cloudinary-api-key-here
CLOUDINARY_API_SECRET=your-cloudinary-api-secret-here

# Mercado Pago Integration
MERCADOPAGO_ACCESS_TOKEN=your-mercadopago-access-token-here

# Contact & Social Media Config (Optional defaults)
NEXT_PUBLIC_SUPPORT_EMAIL=contacto@kuyenchile.cl
NEXT_PUBLIC_PHONE_NUMBER=+56 9 1234 5678
NEXT_PUBLIC_WHATSAPP_NUMBER=+56912345678
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/kuyen_oficial
NEXT_PUBLIC_FACEBOOK_URL=https://facebook.com/kuyen.oficial
NEXT_PUBLIC_TIKTOK_URL=https://tiktok.com/@kuyen_oficial